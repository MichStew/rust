use std::env;
use std::fs; 

fn main() {
    let args : Vec<String> = env::args().collect(); // collect all CLA into a vector of strings
    //dbg!(args);
    let query = &args[1];
    let file_path = &args[2];
    
    let contents = fs::read_to_string(file_path)
        .expect("File not accessible"); 
    println!("with text :\n{contents}");
}
